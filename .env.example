# ─── FRONTEND (Vite — safe to expose, no secrets) ────────────────────────────
VITE_POLAR_CLIENT_ID=your_polar_client_id_here
VITE_POLAR_REDIRECT_URI=https://YOUR-SITE.netlify.app/.netlify/functions/polar-auth

# ─── BACKEND (Netlify functions only — NEVER commit real values) ──────────────
# Set these in Netlify dashboard: Site → Environment variables
POLAR_CLIENT_ID=your_polar_client_id_here
POLAR_CLIENT_SECRET=your_polar_client_secret_here
POLAR_REDIRECT_URI=https://YOUR-SITE.netlify.app/.netlify/functions/polar-auth
